# Identifiant présent dans l'URL du Google Sheet, entre /d/ et /edit.
GOOGLE_SHEETS_SPREADSHEET_ID=

# Compte de service Google Cloud autorisé à modifier le tableur.
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# Conserver les caractères \n si la clé est écrite sur une seule ligne.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

PORT=3000
