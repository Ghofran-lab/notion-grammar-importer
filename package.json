{
  "name": "notion-grammar-importer",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Importer de grammaire française vers PostgreSQL avec export Notion optionnel.",
  "main": "src/index.js",
  "scripts": {
    "db:start": "docker compose up -d",
    "db:stop": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:adminer": "docker compose up -d adminer",
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "check:syntax": "node --check src/index.js && node --check src/db/connection.js && node --check src/db/queries/exercises.js && node --check src/db/queries/rules.js && node --check src/services/seedService.js && node --check src/services/courseSeedService.js && node --check src/server.js && node --check src/public/main.js",
    "db:init": "node scripts/01-init-db.js",
    "db:init:grammar": "node scripts/00-init-grammar-db.js",
    "seed:validate": "node scripts/validate-seed.js",
    "seed:import": "node scripts/02-seed-from-json.js",
    "seed:grammar": "node scripts/04-seed-grammar.js",
    "db:check": "node scripts/03-check-data.js",
    "db:check:grammar": "node scripts/05-check-grammar.js",
    "info": "node scripts/info.js",
    "serve": "node src/server.js",
    "serve:stop": "pkill -f '[n]ode src/server.js' || true",
    "courses:validate": "node scripts/06-validate-courses.js",
    "courses:import": "node scripts/07-import-courses.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@notionhq/client": "^2.2.15",
    "dotenv": "^16.3.1",
    "express": "^4.22.2",
    "pg": "^8.11.0"
  }
}
